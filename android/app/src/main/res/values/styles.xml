<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Thème de lancement -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@color/primary_dark_blue</item>
    </style>

    <!-- Thème normal de l'app -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@color/surface_light</item>
    </style>

    <!-- Thème SPECIFIQUE pour le recadrage (AppCompat requis) -->
    <style name="AppCropperTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">#002366</item>
        <item name="colorPrimaryDark">#001F3F</item>
        <item name="colorAccent">#D4AF37</item>
    </style>
</resources>
