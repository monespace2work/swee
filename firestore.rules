rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isSignedIn() &&
             get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return hasRole('president') || hasRole('tresorier') || hasRole('secretaire');
    }

    // SETTINGS collection
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() &&
                   request.auth.token.auth_time > (request.time.toMillis() - (5 * 60 * 1000)) / 1000;
    }

    // MEMBERS collection
    match /members/{memberId} {
      // Autorise la lecture pour tout le monde (indispensable pour la vérification d'email à l'inscription)
      // Si vous voulez restreindre, vous pouvez utiliser une collection séparée pour les emails autorisés.
      allow read: if true;

      // Création : Soi-même (auto-inscription) OU par un Administrateur
      allow create: if isSignedIn() && (request.auth.uid == memberId || isAdmin());

      // Modification : Soi-même OU Administrateur
      allow update: if isSignedIn() && (request.auth.uid == memberId || isAdmin());

      // Suppression : Président OU migration de compte par l'utilisateur lui-même
      allow delete: if hasRole('president') || (isSignedIn() && resource.data.email == request.auth.token.email);
    }

    // PAYMENTS collection
    match /payments/{id} {
      allow read: if isSignedIn() && (resource.data.memberId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // POSTS collection
    match /posts/{id} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes'])
      );
    }

    // COMMENTS collection
    match /comments/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.memberId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.memberId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.memberId == request.auth.uid || isAdmin());
    }

    // IDEAS collection
    match /ideas/{id} {
      allow read: if isSignedIn() && (resource.data.memberId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.memberId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.memberId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ALERTS collection
    match /alerts/{id} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if (isAdmin() && (resource.data.initiatorId == request.auth.uid || hasRole('president'))) ||
                   (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewedBy', 'remindMeLater', 'dismissedBy']));
      allow delete: if isAdmin() && (resource.data.initiatorId == request.auth.uid || hasRole('president'));
    }
  }
}
